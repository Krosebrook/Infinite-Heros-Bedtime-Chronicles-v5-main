{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "noEmitOnError": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "artifacts",
    "attached_assets",
    "server_dist",
    "static-build",
    "**/*.test.ts",
    "**/*.test.tsx",
    "jest.setup.ts",
    "__tests__/**",
    ".agents/**"
  ]
}
