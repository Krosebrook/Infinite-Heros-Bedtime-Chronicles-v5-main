# =============================================================================
# Infinity Heroes: Bedtime Chronicles — Environment Variables
# =============================================================================

# -- AI Providers --
# At least one text + one image provider is required for story generation.
# API keys are required. *_BASE_URL vars are optional overrides for proxy/custom endpoints.

# Gemini (primary text + image provider)
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# OpenAI (fallback text + image provider)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Anthropic Claude (fallback text provider)
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# OpenRouter (fallback text provider — routes to xAI, Mistral, Cohere, Meta)
AI_INTEGRATIONS_OPENROUTER_API_KEY=
AI_INTEGRATIONS_OPENROUTER_BASE_URL=

# Direct OpenAI key (for video generation via Sora, optional)
OPENAI_API_KEY=

# -- Text-to-Speech --
# ElevenLabs direct API key
ELEVENLABS_API_KEY=

# -- Database --
# PostgreSQL connection URL (required for voice chat/conversation features)
# Supabase project: aeraxfupuvwiskmfjliq (us-east-1) — tables: users, conversations, messages
# Connection string (replace <password> with the DB password from Supabase dashboard → Project Settings → Database):
# DATABASE_URL=postgresql://postgres.aeraxfupuvwiskmfjliq:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# -- Cloudflare KV (optional — enables persistent rate limiting across server restarts) --
# When all three vars are set, the sliding-window rate limiter uses KV instead of in-memory Map.
# KV namespace ID: ed09afa77f9243bbb08f3dbe34df1e70 (infinity-heroes-rate-limit)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# -- Sentry (optional — enables error monitoring) --
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# -- Server Config --
# SESSION_SECRET=your-secret-here
# PORT=5000
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=10
# TTS_CACHE_MAX_AGE_MS=86400000
# Per-call LLM token ceilings (cost guard). Lower these to cap spend per request.
# STORY_MAX_TOKENS=8192
# SUGGEST_MAX_TOKENS=2048

# -- Feature Flags --
# Controls which optional features are active. Omitting a var uses the default shown.
# FEATURE_VIDEO_ENABLED=false          # default off — set to "true" to enable video generation
# FEATURE_VOICE_CHAT_ENABLED=true      # default on  — set to "false" to disable voice chat routes
# FEATURE_STREAMING_ENABLED=true       # default on  — set to "false" to disable SSE story streaming

# -- Client Config --
# EXPO_PUBLIC_API_URL=https://your-api-server.example.com

# -- Supabase Auth --
# Client-side (bundled into app — these are NOT secrets)
# This repo's project URL: https://aeraxfupuvwiskmfjliq.supabase.co (not a secret; set your own for a fork)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-side (SECRET — set as an EAS/deploy secret; never in any EXPO_PUBLIC var or the client bundle)
# SUPABASE_SERVICE_ROLE_KEY=<service_role key from Supabase dashboard → Project Settings → API>
# In production, if the Supabase URL + service-role key are unset, all /api routes requiring auth return 503. No opt-out.

# -- Set automatically by Replit — do not set manually --
# REPLIT_DEV_DOMAIN=
# REPLIT_DOMAINS=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=
# REPLIT_CONNECTORS_HOSTNAME=

# -- Set by Expo dev script — do not set manually --
# EXPO_PUBLIC_DOMAIN=
