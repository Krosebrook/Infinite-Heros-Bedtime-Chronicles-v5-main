# =============================================================================
# Infinity Heroes: Bedtime Chronicles — Environment Variables
# =============================================================================

# -- AI Providers (via Replit AI Integrations) --
# At least one text + one image provider is required for story generation.

# Gemini (primary text + image provider)
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# OpenAI (fallback text + image provider via Replit integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Anthropic Claude (fallback text provider via Replit integrations)
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# OpenRouter (fallback text provider — routes to xAI, Mistral, Cohere, Meta)
AI_INTEGRATIONS_OPENROUTER_API_KEY=
AI_INTEGRATIONS_OPENROUTER_BASE_URL=

# Direct OpenAI key (for video generation via Sora, optional)
OPENAI_API_KEY=

# -- Text-to-Speech --
# ElevenLabs (auto-provisioned by Replit connector; manual key optional)
ELEVENLABS_API_KEY=

# -- Database --
# PostgreSQL connection URL (required for voice chat/conversation features)
DATABASE_URL=

# -- Server Config --
# SESSION_SECRET=your-secret-here
# PORT=5000
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=10
# TTS_CACHE_MAX_AGE_MS=86400000

# -- Feature Flags --
# Controls which optional features are active. Omitting a var uses the default shown.
# FEATURE_VIDEO_ENABLED=false          # default off — set to "true" to enable video generation
# FEATURE_VOICE_CHAT_ENABLED=true      # default on  — set to "false" to disable voice chat routes
# FEATURE_STREAMING_ENABLED=true       # default on  — set to "false" to disable SSE story streaming

# -- Client Config --
# EXPO_PUBLIC_API_URL=https://your-api-server.example.com

# -- Firebase Auth --
# Client-side (bundled into app — these are NOT secrets)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Server-side (secret — set as EAS secret, not in .env)
# FIREBASE_SERVICE_ACCOUNT_KEY=<JSON string of service account key>

# -- Auth Override (DANGEROUS — only for testing) --
# AUTH_DISABLED=true   # Set to bypass auth even without Firebase key (NEVER use in production)

# -- Set automatically by Replit — do not set manually --
# REPLIT_DEV_DOMAIN=
# REPLIT_DOMAINS=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=
# REPLIT_CONNECTORS_HOSTNAME=

# -- Set by Expo dev script — do not set manually --
# EXPO_PUBLIC_DOMAIN=
