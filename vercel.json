{
  "version": 2,
  "nodeVersion": "22.x",
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run server:build",
  "outputDirectory": ".",
  "functions": {
    "api/server.mjs": {
      "maxDuration": 60,
      "includeFiles": "server_dist/**,assets/**,static-build/**,server/templates/**,app.json"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/server" }
  ]
}
