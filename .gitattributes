* text=auto eol=lf

# Explicitly LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.svg       text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.mp3       binary
*.mp4       binary
*.mov       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.zip       binary
*.pdf       binary

# Data / asset text files — preserve their original line endings
*.csv       -text
attached_assets/** -text
