{
  "name": "@krosebrook/infinite-heros-bedtime-chronicles-v5",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "repository": "https://github.com/Krosebrook/Infinite-Heros-Bedtime-Chronicles-v5",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "postinstall": "patch-package || true",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --bundle --format=cjs --outdir=server_dist --minify --external:openai --external:elevenlabs --external:@google/genai --external:@anthropic-ai/sdk --external:firebase-admin --external:drizzle-orm --external:drizzle-orm/node-postgres --external:pg --external:@sentry/node --external:express --external:pino --external:pino-std-serializers --external:zod --external:drizzle-zod",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "npx expo start",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "typecheck": "npx tsc --noEmit",
    "audit": "npm audit --omit=dev",
    "audit:fix": "npm audit fix --omit=dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:components": "jest",
    "preflight": "node scripts/preflight.js"
  },
  "engines": {
    "node": ">=20.19.0 <21 || >=22.13.0 <23",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@expo-google-fonts/bangers": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
