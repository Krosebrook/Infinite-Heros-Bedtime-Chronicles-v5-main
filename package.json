    "@react-native/metro-babel-transformer": "^0.86.0",
    "@react-native/metro-config": "^0.86.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.2.17",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-jest": "^29.7.0",
    "babel-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "msw": "^2.14.6",
    "patch-package": "^8.0.0",
    "react-test-renderer": "^19.2.7",
    "supertest": "^7.2.2",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "yaml": "^2.8.3"
  },
  "private": true,
  "overrides": {
    "yaml": "^2.8.3",
    "p-retry": "8.0.0",
    "shell-quote": "^1.8.4",
    "undici": "^7.10.0",
    "tmp": "^0.2.6"
  }
